{
  "name": "@volleykit/mobile",
  "version": "1.21.3",
  "expo": {
    "install": {
      "exclude": [
        "react"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-widgetkit"
        ]
      }
    }
  },
  "description": "VolleyKit React Native mobile app",
  "type": "module",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild": "expo prebuild",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --max-warnings 0 --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "knip:check": "knip",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "3.0.1",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/bottom-tabs": "^7.10.1",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.14.5",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.90.24",
    "@volleykit/shared": "workspace:*",
    "date-fns": "^4.1.0",
    "expo": "~55.0.7",
    "expo-calendar": "~55.0.10",
    "expo-constants": "~55.0.8",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-local-authentication": "~55.0.9",
    "expo-location": "~55.1.3",
    "expo-notifications": "~55.0.13",
    "expo-router": "~55.0.6",
    "expo-secure-store": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-task-manager": "~55.0.10",
    "nativewind": "^4.2.3",
    "react": "^19.2.4",
    "react-native": "0.84.1",
    "react-native-android-widget": "^0.20.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-widgetkit": "^1.0.9",
    "tailwindcss": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-expo": "~55.0.10",
    "knip": "^5.87.0",
    "react-test-renderer": "^19.2.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
