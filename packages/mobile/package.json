{
  "name": "@volleykit/mobile",
  "version": "1.29.0",
  "expo": {
    "install": {
      "exclude": [
        "react"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-widgetkit"
        ]
      }
    }
  },
  "description": "VolleyKit React Native mobile app",
  "type": "module",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild": "expo prebuild",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --max-warnings 0 --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "knip:check": "knip",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/bottom-tabs": "^7.18.2",
    "@react-navigation/native": "^7.3.3",
    "@react-navigation/native-stack": "^7.17.5",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "@volleykit/shared": "workspace:*",
    "date-fns": "^4.4.0",
    "expo": "~56.0.12",
    "expo-calendar": "~56.0.8",
    "expo-constants": "~56.0.18",
    "expo-font": "~56.0.7",
    "expo-linking": "~56.0.14",
    "expo-local-authentication": "~56.0.4",
    "expo-location": "~56.0.18",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-task-manager": "~56.0.19",
    "nativewind": "^4.2.5",
    "react": "^19.2.7",
    "react-native": "0.83.4",
    "react-native-android-widget": "^0.20.3",
    "react-native-safe-area-context": "5.8.0",
    "react-native-screens": "~4.25.2",
    "react-native-widgetkit": "^1.0.9",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.14",
    "eslint": "^10.5.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "knip": "^6.17.1",
    "react-test-renderer": "^19.2.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.61.1"
  }
}
