{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["e2e/**/*.ts", "src/features/*/index.ts"],
  "project": ["src/**/*.{ts,tsx}", "e2e/**/*.ts"],
  "ignore": ["src/types/**/*.d.ts"],
  "ignoreDependencies": ["tailwindcss", "@volleykit/shared"],
  "ignoreBinaries": ["changeset"],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "duplicates": "off"
  }
}
