{
  "name": "volleykit-web",
  "description": "VolleyKit - Swiss Volleyball Referee Management PWA",
  "private": true,
  "version": "1.30.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"e2e/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"e2e/**/*.ts\"",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --max-warnings 0 --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "screenshots:help": "playwright test e2e/capture-screenshots.spec.ts --project=chromium",
    "size": "size-limit",
    "preview": "vite preview",
    "generate:api": "openapi-typescript ../../docs/api/volleymanager-openapi.yaml -o ../shared/src/api/schema.ts",
    "knip": "knip",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status"
  },
  "size-limit": [
    {
      "name": "Main App Bundle",
      "path": "dist/assets/index-*.js",
      "limit": "30 kB",
      "gzip": true
    },
    {
      "name": "Vendor Chunks",
      "path": [
        "dist/assets/chunk-react-vendor-*.js",
        "dist/assets/chunk-router-*.js",
        "dist/assets/chunk-state-*.js",
        "dist/assets/chunk-validation-*.js"
      ],
      "limit": "115 kB",
      "gzip": true
    },
    {
      "name": "PDF Library (lazy-loaded)",
      "path": "dist/assets/chunk-pdf-lib-*.js",
      "limit": "185 kB",
      "gzip": true
    },
    {
      "name": "Image Cropper (lazy-loaded)",
      "path": "dist/assets/chunk-cropper-*.js",
      "limit": "11 kB",
      "gzip": true
    },
    {
      "name": "CSS Bundle",
      "path": "dist/assets/*.css",
      "limit": "13 kB",
      "gzip": true
    },
    {
      "name": "Total JS Bundle",
      "path": "dist/assets/*.js",
      "limit": "690 kB",
      "gzip": true
    }
  ],
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-persist-client": "^5.96.2",
    "@volleykit/shared": "workspace:*",
    "date-fns": "^4.1.0",
    "fuse.js": "^7.3.0",
    "idb": "^8.0.3",
    "lucide-react": "^1.7.0",
    "ojp-sdk-next": "^0.21.4",
    "pdf-lib": "^1.17.1",
    "pluscodes": "^3.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.7",
    "react-router-dom": "^7.14.0",
    "signature_pad": "^5.1.3",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.4",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@rolldown/plugin-babel": "^0.2.2",
    "@size-limit/file": "^12.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.2.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "knip": "^6.3.0",
    "msw": "^2.12.14",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "size-limit": "^12.0.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  }
}
