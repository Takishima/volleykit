{
  "name": "volleykit",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status",
    "generate:api": "pnpm --filter volleykit-web run generate:api",
    "generate:tokens": "node scripts/sync-style-tokens.js",
    "generate:tokens:check": "node scripts/sync-style-tokens.js --check",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,json,css,md,astro}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,json,css,md,astro}\"",
    "test": "pnpm -r run test",
    "build": "pnpm -r run build",
    "mobile:start": "pnpm --filter @volleykit/mobile run start",
    "mobile:ios": "pnpm --filter @volleykit/mobile run ios",
    "mobile:android": "pnpm --filter @volleykit/mobile run android",
    "shared:build": "pnpm --filter @volleykit/shared run build",
    "shared:test": "pnpm --filter @volleykit/shared run test"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@types/react": "^19.2.14",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "^5.5.7",
      "@types/react": "^19.2.14",
      "axios": "^1.12.0",
      "jsdom": "^27.4.0",
      "@xmldom/xmldom": "^0.8.11",
      "react": "^19.2.5",
      "react-native-screens": "~4.24.0",
      "devalue": "^5.6.4",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "flatted@<=3.4.1": ">=3.4.2",
      "h3@<1.15.9": ">=1.15.9",
      "smol-toml@<1.6.1": ">=1.6.1",
      "happy-dom@>=15.10.0 <=20.8.7": ">=20.8.8",
      "serialize-javascript@<7.0.5": ">=7.0.5",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "node-forge@<=1.3.3": ">=1.4.0",
      "node-forge@<1.4.0": ">=1.4.0",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "vite": "8.0.9"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver",
      "workerd"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
