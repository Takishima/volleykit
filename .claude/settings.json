{
  "permissions": {
    "allow": [
      "Bash(nix-build:*)",
      "Bash(nix build:*)",
      "Bash(nix-store --query:*)",
      "Bash(nix-store --verify:*)",
      "Bash(nix-store --dump:*)",
      "Bash(nix-store --export:*)",
      "Bash(nix show-derivation:*)",
      "Bash(nix-instantiate:*)",
      "Bash(nix-env:*)",
      "Bash(nix search:*)",
      "Bash(nix develop:*)",
      "Bash(nix-shell:*)",
      "Bash(nix flake:*)",
      "Bash(nix profile:*)",
      "Bash(nix run:*)",
      "Bash(nix fmt:*)",
      "Bash(devenv shell:*)",
      "Read(/nix/store/*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm run build:*)",
      "Bash(pnpm run dev:*)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm run preview:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm run test:*)",
      "Bash(pnpm run generate:*)",
      "Bash(pnpm exec tsc:*)",
      "Bash(pnpm exec vitest:*)",
      "Bash(pnpm exec eslint:*)",
      "Bash(pnpm exec wrangler:*)",
      "Bash(pnpm run size:*)",
      "Bash(CLAUDE_CODE_REMOTE=true scripts/pre-commit-validate.sh)",
      "Bash(prettier --check:*)"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-git-commit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-git-push.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-git-commit.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-read-validation.sh"
          }
        ]
      }
    ]
  }
}
